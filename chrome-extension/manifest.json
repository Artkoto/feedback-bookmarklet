{
  "manifest_version": 3,
  "name": "Feedback Tool",
  "version": "1.1",
  "description": "Outil de feedback visuel — injecter avec Alt+Shift+F",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-feedback": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Alt+F",
        "windows": "Ctrl+Shift+F",
        "linux": "Ctrl+Shift+F"
      },
      "description": "Afficher / masquer l'outil de feedback"
    }
  }
}
